test "regex canonical operations" {
    assert(regex.test("[a-z]+", "fidan"))
    assert_eq(regex.match("[0-9]+", "abc123xyz"), "123")
    var all_matches = regex.findAll("[0-9]+", "a1b22c333")
    assert_eq(len(all_matches), 3)
    assert_eq(all_matches[1], "22")
    var captured = regex.capture("([a-z]+)([0-9]+)", "abc123")
    assert_eq(captured[0], "abc123")
    assert_eq(captured[1], "abc")
    assert_eq(captured[2], "123")
    var captured_all = regex.captureAll("([a-z])([0-9])", "a1 b2")
    assert_eq(len(captured_all), 2)
    assert_eq(captured_all[1][1], "b")
    assert_eq(regex.replace("cat", "cat nap", "dog"), "dog nap")
    assert_eq(regex.replaceAll("[0-9]+", "a1b22", "#"), "a#b#")
    var split_parts = regex.split("[,:]", "a,b:c")
    assert_eq(len(split_parts), 3)
    assert(regex.isValid("[a-z]+"))
    assert(not regex.isValid("["))
}

test "regex alias operations" {
    assert(regex.isMatch("f.d", "fidan"))
    assert(regex.is_match("f.d", "fidan"))
    assert_eq(regex.find("dog", "dog park"), "dog")
    assert_eq(regex.find_first("park", "dog park"), "park")
    var alias_matches = regex.matches("[A-Z]", "A b C")
    assert_eq(len(alias_matches), 2)
    var exec_one = regex.exec("([A-Z])([0-9])", "Q7")
    assert_eq(exec_one[1], "Q")
    assert_eq(exec_one[2], "7")
    var exec_all = regex.execAll("([A-Z])([0-9])", "Q7 R8")
    assert_eq(len(exec_all), 2)
    assert_eq(exec_all[0][0], "Q7")
    assert_eq(exec_all[1][0], "R8")
    assert_eq(regex.exec_all("([A-Z])([0-9])", "Q7")[0][0], "Q7")
    assert_eq(regex.replace_first("[0-9]+", "a1b2", "#"), "a#b2")
    assert(regex.is_valid("[0-9]+"))
}

test "time canonical operations" {
    var now_ms = time.now()
    var unix_s = time.timestamp()
    assert_eq(type(now_ms), "integer")
    assert_eq(type(unix_s), "integer")
    assert(now_ms > 0)
    assert(unix_s > 0)
    time.sleep(1)
    time.wait(1)
    assert(time.elapsed(now_ms) >= 0)
    assert(len(time.date()) == 10)
    assert(len(time.time()) == 8)
    assert(len(time.datetime()) == 19)
    assert_eq(type(time.year()), "integer")
    assert_eq(type(time.month()), "integer")
    assert_eq(type(time.day()), "integer")
    assert_eq(type(time.hour()), "integer")
    assert_eq(type(time.minute()), "integer")
    assert_eq(type(time.second()), "integer")
    assert_eq(type(time.weekday()), "integer")
}

test "time explicit formatting" {
    var fixed = 1700000000000
    assert_eq(time.date(fixed), "2023-11-14")
    assert_eq(time.time(fixed), "22:13:20")
    assert_eq(time.datetime(fixed), "2023-11-14 22:13:20")
    assert_eq(time.format(fixed), "2023-11-14 22:13:20")
    assert_eq(time.format(fixed, "%Y/%m/%d"), "2023/11/14")
    assert_eq(time.format(fixed, "YYYY-MM-DD"), "2023-11-14")
    assert_eq(time.format(fixed, "HH:mm:ss"), "22:13:20")
}

test "io file and path operations" {
    var root = io.joinPath(".", "LOCAL", "release-mega-test")
    assert(io.makeDir(root))
    assert(io.isDir(root))
    var file_a = io.join(root, "a.txt")
    var file_b = io.join(root, "b.txt")
    var file_c = io.join(root, "c.txt")
    assert(io.writeFile(file_a, "hello"))
    assert(io.appendFile(file_a, " world"))
    assert(io.fileExists(file_a))
    assert(io.exists(file_a))
    assert(io.isFile(file_a))
    assert_eq(io.readFile(file_a), "hello world")
    assert(io.copyFile(file_a, file_b))
    assert(io.renameFile(file_b, file_c))
    assert(io.fileExists(file_c))
    assert_eq(io.basename(file_c), "c.txt")
    assert_eq(io.fileName(file_c), "c.txt")
    assert_eq(io.extension(file_c), "txt")
    assert(io.dirname(file_c).contains("release-mega-test"))
    assert(io.absolutePath(file_c).contains("release-mega-test"))
    var listing = io.listDir(root)
    assert(len(listing) >= 2)
    var listing2 = io.readDir(root)
    assert(len(listing2) >= 2)
    assert(io.deleteFile(file_a))
    assert(io.deleteFile(file_c))
}

test "io env and alias operations" {
    io.setEnv("FIDAN_RELEASE_MEGA", "ok")
    assert_eq(io.getEnv("FIDAN_RELEASE_MEGA"), "ok")
    assert_eq(io.get_env("FIDAN_RELEASE_MEGA"), "ok")
    assert_eq(io.env("FIDAN_RELEASE_MEGA"), "ok")
    var alias_root = io.join_path(".", "LOCAL", "release-mega-alias")
    assert(io.mkdir(alias_root))
    var alias_file = io.joinPath(alias_root, "alias.txt")
    assert(io.write_file(alias_file, "x"))
    assert(io.append_file(alias_file, "y"))
    assert_eq(io.read_file(alias_file), "xy")
    assert(io.file_exists(alias_file))
    assert(io.is_file(alias_file))
    assert(io.base_name(alias_file) == "alias.txt")
    assert(io.dir_name(alias_file).contains("release-mega-alias"))
    assert(io.current_dir().lower().contains("fidan"))
    assert(io.currentDir().lower().contains("fidan"))
    assert_eq(type(io.args()), "list")
    assert_eq(type(io.argv()), "list")
    assert_eq(type(io.isatty()), "boolean")
    assert_eq(type(io.isatty("stderr")), "boolean")
    io.flush()
    assert(io.delete_file(alias_file))
}

test "type len and helpers" {
    assert_eq(type(1), "integer")
    assert_eq(type(1.5), "float")
    assert_eq(type(true), "boolean")
    assert_eq(type("hello"), "string")
    assert_eq(type([1, 2]), "list")
    assert_eq(type({"a": 1}), "dict")
    assert_eq(type(nothing), "nothing")
    assert_eq(len([1, 2, 3]), 3)
    assert_eq(len({"a": 1, "b": 2}), 2)
    assert_eq(len("abc"), 3)
    assert_eq(type(Shared(1)), "Shared")
    var weak_source = Shared(5)
    var weak_ref = WeakShared(weak_source)
    assert_eq(type(weak_ref), "WeakShared")
    assert_eq(weak_ref.isAlive(), true)
    var upgraded_weak = weak_ref.upgrade()
    assert_eq(type(upgraded_weak), "Shared")
    assert_eq(upgraded_weak.get(), 5)
    upgraded_weak = nothing
    weak_source = nothing
    assert_eq(weak_ref.isAlive(), false)
    assert_eq(weak_ref.upgrade(), nothing)
}

test "receiver helpers and lambdas" {
    var nums = [1, 3, 4, 8]
    assert_eq(nums.firstWhere(is_even), 4)
    assert_eq(nums.firstWhere(greater_than_five), 8)
    assert_eq(nums.firstWhere(action with (certain x oftype integer) returns boolean { return x >= 8 }), 8)
    var total = Shared(0)
    nums.forEach(action with (certain x oftype integer) {
        total.set(total.get() + x)
    })
    assert_eq(total.get(), 16)
}

test "ffi cpp native smoke" {
    if io.fileExists("./LOCAL/extern-cpp/ffi_demo.dll") {
        assert_eq(cppAdd(20, 22), 42)
        assert(approx_equal(cppScale(2.5, 4.0), 10.0))
        assert_eq(cppSum3(10, 20, 12), 42)
        var handle = cppMakeHandle()
        assert_eq(cppMix4(7, 8.0, true, handle), 156)
        assert(cppNegate(false))
        handle = cppIncHandle(handle)
        assert_eq(cppReadHandle(handle), 42)
        cppFreeHandle(handle)
    }
}

