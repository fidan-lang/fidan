# utils.fdn — a small library file imported by import_test.fdn

const var PI = 3.14159

action greet with (certain name oftype string) returns string {
    return "Hello from utils, " + name + "!"
}

action square with (certain n oftype integer) returns integer {
    return n * n
}

# Note: PI is a module-level const; passing it as a parameter demonstrates
# the cross-file import mechanism cleanly until module-global scoping lands.
action circle_area with (certain pi oftype float, certain radius oftype float) returns float {
    return pi * radius * radius
}
