test "error handling nested attempt" {
    attempt {
        attempt {
            panic("inner boom")
        } rescue err {
            assert_eq(err, "inner boom")
            panic("outer boom")
        }
    } rescue err {
        assert_eq(err, "outer boom")
    }
}

test "global state touchpoints" {
    GLOBAL_COUNTER = GLOBAL_COUNTER + 1
    GLOBAL_GREETING = GLOBAL_GREETING + "!"
    GLOBAL_SCORES["gamma"] = 3
    assert(GLOBAL_COUNTER >= 1)
    assert(GLOBAL_GREETING.contains("release"))
    assert_eq(GLOBAL_SCORES["gamma"], 3)
}

test "mega integration composite" {
    var ledger = Ledger("Composite")
    for n in collections.range(1, 6) {
        ledger.add(n)
    }
    var summary = ledger.describe()
    assert(summary.contains("Composite"))
    assert(summary.contains("15"))
    var found = regex.match("[0-9]+", summary)
    assert_eq(found, "15")
    var shared = Shared(0)
    parallel for n in [10, 11, 12, 9] {
        shared.set(shared.get() + 1)
    }
    assert(shared.get() >= 1)
}

