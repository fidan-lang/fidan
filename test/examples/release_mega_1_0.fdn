test "math trig functions" {
    assert(approx_equal(math.sin(0.0), 0.0))
    assert(approx_equal(math.cos(0.0), 1.0))
    assert(approx_equal(math.tan(0.0), 0.0))
    assert(approx_equal(math.asin(0.0), 0.0))
    assert(approx_equal(math.acos(1.0), 0.0))
    assert(approx_equal(math.atan(0.0), 0.0))
}

test "math hyperbolic functions" {
    assert(approx_equal(math.sinh(0.0), 0.0))
    assert(approx_equal(math.cosh(0.0), 1.0))
    assert(approx_equal(math.tanh(0.0), 0.0))
}

test "math roots and powers" {
    assert(approx_equal(math.sqrt(16.0), 4.0))
    assert(approx_equal(math.cbrt(27.0), 3.0))
    assert(approx_equal(math.pow(2.0, 5.0), 32.0))
    assert(approx_equal(math.hypot(3.0, 4.0), 5.0))
}

test "math exponentials and logs" {
    assert(approx_equal(math.exp(0.0), 1.0))
    assert(approx_equal(math.exp2(3.0), 8.0))
    assert(approx_equal(math.log(math.e()), 1.0))
    assert(approx_equal(math.log2(8.0), 3.0))
    assert(approx_equal(math.log10(1000.0), 3.0))
    assert(approx_equal(math.logN(27.0, 3.0), 3.0))
}

test "math rounding helpers" {
    assert_eq(math.floor(3.9), 3)
    assert_eq(math.ceil(3.1), 4)
    assert_eq(math.round(2.5), 3)
    assert(approx_equal(math.trunc(9.8), 9.0))
    assert(approx_equal(math.fract(3.25), 0.25))
}

test "math abs sign min max clamp" {
    assert_eq(math.abs(-7), 7)
    assert(approx_equal(math.abs(-7.5), 7.5))
    assert_eq(math.sign(-8), -1)
    assert_eq(math.signum(0), 0)
    assert_eq(math.min(4, 9), 4)
    assert_eq(math.max(4, 9), 9)
    assert(approx_equal(math.clamp(12, 0, 10), 10.0))
    assert(approx_equal(math.clamp(-2, 0, 10), 0.0))
}

test "math constants and predicates" {
    assert(approx_equal(math.pi(), 3.141592653589793))
    assert(approx_equal(math.e(), 2.718281828459045))
    assert(approx_equal(math.tau(), 6.283185307179586))
    assert(math.isFinite(5.0))
    assert(math.is_finite(5.0))
    assert(math.isInfinite(math.inf()))
    assert(math.is_infinite(math.inf()))
    assert(math.isNan(math.nan()))
    assert(math.is_nan(math.nan()))
}

test "math random and conversion helpers" {
    var r = math.random()
    assert(r >= 0.0)
    assert(r < 1.0)
    var ri = math.randomInt(10, 20)
    assert(ri >= 10)
    assert(ri < 20)
    assert_eq(type(ri), "integer")
    assert(approx_equal(math.toDeg(math.pi()), 180.0))
    assert(approx_equal(math.to_deg(math.pi()), 180.0))
    assert(approx_equal(math.degrees(math.pi()), 180.0))
    assert(approx_equal(math.toRad(180.0), math.pi()))
    assert(approx_equal(math.to_rad(180.0), math.pi()))
    assert(approx_equal(math.radians(180.0), math.pi()))
    assert(approx_equal(math.atan2(0.0, 1.0), 0.0))
}

test "string canonical operations" {
    assert_eq(strings.toUpper("fidan"), "FIDAN")
    assert_eq(strings.toLower("Fidan"), "fidan")
    assert_eq(strings.capitalize("hello"), "Hello")
    assert_eq(strings.trim("  hi  "), "hi")
    assert_eq(strings.trimStart("  hi"), "hi")
    assert_eq(strings.trimEnd("hi  "), "hi")
    var parts = strings.split("a,b,c", ",")
    assert_eq(len(parts), 3)
    assert_eq(strings.join("-", parts), "a-b-c")
    var lines_list = strings.lines("a\nb\nc")
    assert_eq(len(lines_list), 3)
    assert(strings.contains("abcdef", "bcd"))
    assert(strings.startsWith("abcdef", "abc"))
    assert(strings.endsWith("abcdef", "def"))
    assert_eq(strings.indexOf("abcdef", "cd"), 2)
    assert_eq(strings.lastIndexOf("ababa", "ba"), 3)
}

test "string replacement substring and padding" {
    assert_eq(strings.replace("abcabc", "a", "x"), "xbcxbc")
    assert_eq(strings.replaceFirst("abcabc", "a", "x"), "xbcabc")
    assert_eq(strings.slice("abcdef", 1, 4), "bcd")
    assert_eq(strings.substr("abcdef", 2, 5), "cde")
    assert_eq(strings.padStart("7", 3, "0"), "007")
    assert_eq(strings.padEnd("7", 3, "0"), "700")
    assert_eq(strings.repeat("ha", 3), "hahaha")
    assert_eq(strings.reverse("abc"), "cba")
    assert_eq(strings.len("abc"), 3)
    assert_eq(strings.length("abcd"), 4)
    assert(strings.isEmpty(""))
    assert(strings.is_empty(""))
}

test "string formatting parsing and code helpers" {
    var fmt_sentence = "Hello " + strings.fromCharCode(123) + strings.fromCharCode(125) + ", you have " + strings.fromCharCode(123) + strings.fromCharCode(125)
    assert_eq(strings.format(fmt_sentence, "Ada", 3), "Hello Ada, you have 3")
    assert_eq(strings.parseInt("42"), 42)
    assert(approx_equal(strings.parseFloat("3.5"), 3.5))
    var chars_list = strings.chars("Fidan")
    assert_eq(len(chars_list), 5)
    assert_eq(chars_list[0], "F")
    var bytes_list = strings.bytes("AZ")
    assert_eq(len(bytes_list), 2)
    assert_eq(bytes_list[0], 65)
    assert_eq(bytes_list[1], 90)
    assert_eq(strings.fromChars(["O", "K"]), "OK")
    assert_eq(strings.charCode("A"), 65)
    assert_eq(strings.fromCharCode(66), "B")
}

test "string alias operations" {
    assert_eq(strings.upper("abc"), "ABC")
    assert_eq(strings.to_upper("abc"), "ABC")
    assert_eq(strings.lower("ABC"), "abc")
    assert_eq(strings.to_lower("ABC"), "abc")
    assert_eq(strings.ltrim("  x"), "x")
    assert_eq(strings.trim_start("  x"), "x")
    assert_eq(strings.rtrim("x  "), "x")
    assert_eq(strings.trim_end("x  "), "x")
    assert(strings.starts_with("abcdef", "abc"))
    assert(strings.ends_with("abcdef", "def"))
    assert_eq(strings.index_of("abcdef", "bc"), 1)
    assert_eq(strings.last_index_of("ababa", "ba"), 3)
    assert_eq(strings.replace_first("abcabc", "a", "z"), "zbcabc")
    assert_eq(strings.pad_start("9", 2, "0"), "09")
    assert_eq(strings.pad_end("9", 2, "0"), "90")
    assert_eq(strings.parse_int("55"), 55)
    assert(approx_equal(strings.parse_float("5.5"), 5.5))
    assert_eq(strings.from_chars(["Y", "o"]), "Yo")
    assert_eq(strings.char_code("C"), 67)
    assert_eq(strings.from_char_code(68), "D")
}

test "collections range and set operations" {
    var seq = collections.range(2, 7)
    assert_eq(len(seq), 5)
    assert_eq(seq[0], 2)
    assert_eq(seq[4], 6)
    var backward = collections.range(5, 0, -2)
    assert_eq(len(backward), 3)
    assert_eq(backward[0], 5)
    assert_eq(backward[2], 1)
    var set_a = collections.hashset(["a", "b", "b"])
    var set_b = collections.hashset(["b", "c"])
    assert(collections.setContains(set_a, "a"))
    assert_eq(collections.setLen(set_a), 2)
    var unioned = collections.setUnion(set_a, set_b)
    var intersected = collections.setIntersect(set_a, set_b)
    var diffed = collections.setDiff(set_a, set_b)
    assert(collections.setContains(unioned, "c"))
    assert(collections.setContains(intersected, "b"))
    assert(collections.setContains(diffed, "a"))
    collections.setAdd(set_a, "z")
    assert(collections.setContains(set_a, "z"))
    collections.setRemove(set_a, "z")
    assert(not collections.setContains(set_a, "z"))
    var set_list = collections.setToList(unioned)
    assert(len(set_list) >= 3)
}

test "collections queue and stack operations" {
    var queue = collections.Queue([1, 2])
    assert_eq(collections.peek(queue), 1)
    collections.enqueue(queue, 3)
    assert_eq(collections.dequeue(queue), 1)
    assert_eq(collections.dequeue(queue), 2)
    assert_eq(collections.dequeue(queue), 3)
    var stack = collections.Stack([1, 2])
    assert_eq(collections.top(stack), 2)
    collections.push(stack, 5)
    assert_eq(collections.stackPeek(stack), 5)
    assert_eq(collections.pop(stack), 5)
    assert_eq(collections.pop(stack), 2)
    assert_eq(collections.pop(stack), 1)
}

test "collections list utilities" {
    var flattened = collections.flatten([[1, 2], [3], 4])
    assert_eq(len(flattened), 4)
    var zipped = collections.zip(["a", "b"], [1, 2, 3])
    assert_eq(len(zipped), 2)
    assert_eq(zipped[0][0], "a")
    assert_eq(zipped[0][1], 1)
    var deduped = collections.unique([1, 2, 2, 3, 3, 3])
    assert_eq(len(deduped), 3)
    assert_eq(collections.reverse([1, 2, 3])[0], 3)
    assert_eq(collections.sort([5, 3, 4, 1])[0], 1)
    assert_eq(collections.count([9, 8, 7]), 3)
    assert_eq(collections.length([9, 8, 7]), 3)
    assert_eq(collections.len([9, 8, 7]), 3)
    assert(collections.isEmpty([]))
    assert(collections.is_empty([]))
    var concatenated = collections.concat([1, 2], [3], [4, 5])
    assert_eq(len(concatenated), 5)
    assert_eq(collections.slice([1, 2, 3, 4], 1, 3)[0], 2)
    assert_eq(collections.first([7, 8, 9]), 7)
    assert_eq(collections.last([7, 8, 9]), 9)
    assert_eq(collections.join(["a", "b", "c"], "-"), "a-b-c")
    assert_eq(collections.sum([1, 2, 3, 4]), 10)
    assert_eq(collections.product([1, 2, 3, 4]), 24)
    assert_eq(collections.min([7, 3, 5]), 3)
    assert_eq(collections.max([7, 3, 5]), 7)
}

test "collections alias operations" {
    var alias_set = collections.hashset(["red", "blue"])
    collections.set_add(alias_set, "green")
    assert(collections.set_contains(alias_set, "green"))
    assert_eq(collections.set_len(alias_set), 3)
    collections.set_remove(alias_set, "green")
    assert(not collections.set_contains(alias_set, "green"))
    var alias_union = collections.set_union(alias_set, collections.hashset(["blue", "yellow"]))
    var alias_intersection = collections.set_intersect(alias_set, collections.hashset(["blue", "white"]))
    var alias_diff = collections.set_diff(alias_set, collections.hashset(["red"]))
    assert(collections.set_contains(alias_union, "yellow"))
    assert(collections.set_contains(alias_intersection, "blue"))
    assert(collections.set_contains(alias_diff, "blue"))
    var alias_list = collections.set_to_list(alias_union)
    assert(len(alias_list) >= 3)
    var stack = collections.Stack([])
    collections.push(stack, 11)
    assert_eq(collections.stack_peek(stack), 11)
    assert_eq(collections.pop(stack), 11)
    var deduped = collections.dedup([1, 1, 2, 3, 3])
    assert_eq(len(deduped), 3)
}

