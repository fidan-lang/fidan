## TEST PROGRAM ## (Comment using `#` for single-line comments or `#/ ... /#` for multi-line comments (can be nested))

#/
var x set 10 # declare a variable (type is inferred automatically)
var x oftype integer # declare a variable with an explicit type, but without initializing it
# Declared variables with no value are automatically initialized to `nothing`.
# All types are nullable (nothing) by default, so you can assign `nothing` to any variable regardless of its type.
/#

object Creature {
    var species oftype string = "Unknown"

    new with (optional species oftype string default "Unknown") { # If nothing is passed for species, it defaults to "Unknown" (if `nothing` is passed, it will NOT be treated as "Unknown"!!!)
        this.species = species
    }

    action speak returns string {
        return "Hello, I am a {this.species}!"
    }
}

object Person extends Creature {
    var name oftype string
    var age oftype integer

    # Can use `also` or `,` to separate parameters in the same parameter list
    # `required` means the parameter must be passed when calling the action, otherwise it will throw an error
    # You can wrap parameters in parentheses to group them together for readability, but it's not required
    new with (required name oftype string also optional age oftype integer = 18) { # `=` is an alias for `default` or rather `set`
        this.name = name
        this.age = age

        parent(species set "Human")
    }

    action introduce returns nothing {
        print("My name is {this.name} and I am {this.age} years old!")
    }
}

action greet extends Person with (optional person oftype Person) { ## No default value means it defaults to `nothing`
    ## Can be used like this:
    ## 1. var john = Person("John" also 20)
    ##    john.greet()
    ## 2. greet(Person("John" also 20))

    ## Check if the person param is passed, else use the extended object
    ## `nothing` in this ternary operator/context refers to the first option (the person parameter), not the second option (this)
    var personToGreet = person if is not nothing else this ## Or: `var personToGreet = person if (person != nothing) else this` or `person ?? this` (null-coalescing operator)

    print("Hello, {personToGreet.name}!")
}

action main {
    var john set Person("John" also 20) ## Optionally: var person = Person.initialize("John" also 20)
    var jennifer set Person(name set "Jennifer", age = 18) ## Optionally: var person = Person.initialize(name = "Jennifer" also age = 18)
    john.introduce()
    greet(jennifer)

    ## Some calculations
    var x set 10 ## Type is inferred automatically
    var y set 20
    var z = (x + y) / 2
    print(z)

    if john.age greaterthan jennifer.age {
        print("John is older than Jennifer!")
    } otherwise when john.age equals jennifer.age { # Can use `is` instead of `equals` for equality check, and `else if` instead of `otherwise when`
        print("John and Jennifer are the same age!")
    } else {
        print("Jennifer is older than John!")
    }

    attempt { ## Can also be used with 'try' instead of 'attempt'
        panic("An error occurred!") ## Throw an error, can also use `throw` instead of `panic`
    } catch error {
        print(error)
    } otherwise {
        print("Only executed if no error is thrown!")
    } finally {
        print("This is the end of the script!")
    }
}

print("Hello, world!") ## Print a message
main() ## Call the main action