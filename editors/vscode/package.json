{
    "name": "fidan",
    "displayName": "Fidan",
    "description": "Syntax highlighting, formatting and language server support for the Fidan programming language.",
    "version": "1.0.0",
    "publisher": "AppSolves",
    "license": "Fidan Programming Language License (FPLL) 1.0.0",
    "icon": "./icons/icon_128x128.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/AppSolves/fidan"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Linters",
        "Debuggers",
        "Snippets"
    ],
    "keywords": [
        "fidan",
        "fdn"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "fidan",
                "aliases": [
                    "Fidan",
                    "fidan"
                ],
                "extensions": [
                    ".fdn"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/icon.png",
                    "dark": "./icons/icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "fidan",
                "scopeName": "source.fidan",
                "path": "./syntaxes/fidan.tmLanguage.json"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "fidan",
                "scopes": {
                    "function": [
                        "entity.name.function.fidan"
                    ],
                    "function.declaration": [
                        "entity.name.function.fidan"
                    ],
                    "method": [
                        "entity.name.function.member.fidan"
                    ],
                    "method.declaration": [
                        "entity.name.function.member.fidan"
                    ],
                    "class": [
                        "entity.name.class.fidan"
                    ],
                    "class.declaration": [
                        "entity.name.class.fidan"
                    ],
                    "variable": [
                        "variable.other.readwrite.fidan"
                    ],
                    "variable.declaration": [
                        "variable.other.readwrite.fidan"
                    ],
                    "variable.declaration.readonly": [
                        "variable.other.constant.fidan"
                    ],
                    "parameter": [
                        "variable.parameter.fidan"
                    ],
                    "parameter.declaration": [
                        "variable.parameter.fidan"
                    ],
                    "property": [
                        "variable.other.property.fidan"
                    ],
                    "type": [
                        "support.type.primitive.fidan"
                    ]
                }
            }
        ],
        "configuration": {
            "title": "Fidan",
            "properties": {
                "fidan.server.path": {
                    "type": "string",
                    "default": "fidan",
                    "description": "Path to the `fidan` binary used for the language server. Defaults to `fidan` on PATH."
                },
                "fidan.server.extraArgs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Extra arguments forwarded to `fidan lsp`."
                },
                "fidan.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace LSP communication in the Output channel."
                },
                "fidan.format.indentWidth": {
                    "type": "number",
                    "default": 4,
                    "description": "Number of spaces per indent level used by `fidan fmt`."
                },
                "fidan.format.maxLineLen": {
                    "type": "number",
                    "default": 100,
                    "description": "Target maximum line length used by `fidan fmt`."
                },
                "fidan.format.onSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Format Fidan files automatically on save."
                },
                "fidan.run.terminalName": {
                    "type": "string",
                    "default": "Fidan",
                    "description": "Name of the integrated terminal used by the 'Fidan: Run Current File' command."
                }
            }
        },
        "snippets": [
            {
                "language": "fidan",
                "path": "./syntaxes/fidan.code-snippets.json"
            }
        ],
        "commands": [
            {
                "command": "fidan.restartServer",
                "title": "Fidan: Restart Language Server"
            },
            {
                "command": "fidan.showOutput",
                "title": "Fidan: Show Language Server Output"
            },
            {
                "command": "fidan.runFile",
                "title": "Fidan: Run Current File",
                "icon": "$(play)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "fidan.runFile",
                    "when": "resourceLangId == fidan",
                    "group": "navigation"
                }
            ]
        },
        "configurationDefaults": {
            "[fidan]": {
                "editor.semanticHighlighting.enabled": true
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "typescript": "^5.4.0"
    }
}