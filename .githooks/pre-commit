#!/bin/sh

set -eu

staged_rust_files="$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')"

if [ -z "$staged_rust_files" ]; then
  exit 0
fi

echo "pre-commit: running cargo fmt --all"
cargo fmt --all

echo "$staged_rust_files" | while IFS= read -r file; do
  if [ -n "$file" ] && [ -f "$file" ]; then
    git add "$file"
  fi
done

echo "pre-commit: Rust files formatted and re-staged"
echo "pre-commit: running cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-commit: cargo fmt and cargo clippy passed"
