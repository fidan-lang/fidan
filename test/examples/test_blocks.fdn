# test_blocks.fdn — demonstrates Fidan's built-in test{} syntax.
# Run with:  fidan test test/examples/test_blocks.fdn

# --- top-level setup (shared across all tests) ---
var PI = 3.14159

action add with (certain a oftype integer, certain b oftype integer) returns integer {
    return a + b
}

action greet with (certain name oftype string) returns string {
    return "Hello, " + name + "!"
}

# ── arithmetic ─────────────────────────────────────────────────────────────────

test "basic arithmetic" {
    assert(1 + 1 == 2)
    assert(10 - 3 == 7)
    assert(4 * 5 == 20)
    assert_eq(100 / 4, 25)
    assert_ne(1 + 1, 3)
}

test "integer helpers" {
    assert_eq(add(3, 7), 10)
    assert_eq(add(0, 0), 0)
    assert_eq(add(-5, 5), 0)
}

# ── strings ────────────────────────────────────────────────────────────────────

test "string operations" {
    var s = "hello"
    assert(len(s) == 5)
    assert_ne(s, "world")
    assert_eq(greet("Fidan"), "Hello, Fidan!")
}

test "string equality" {
    assert_eq("abc", "abc")
    assert_ne("abc", "ABC")
}

# ── booleans ───────────────────────────────────────────────────────────────────

test "boolean logic" {
    assert(true)
    assert(!false)
    assert(true and true)
    assert(!(false and true))
    assert(false or true)
}

# ── lists ──────────────────────────────────────────────────────────────────────

test "list basics" {
    var xs = [1, 2, 3, 4, 5]
    assert_eq(len(xs), 5)
    assert_eq(xs[0], 1)
    assert_eq(xs[4], 5)
}

test "list comprehension" {
    var even = [x for x in [1, 2, 3, 4, 5, 6] if x % 2 == 0]
    assert_eq(len(even), 3)
    assert_eq(even[0], 2)
    assert_eq(even[2], 6)
}

# ── comparisons ────────────────────────────────────────────────────────────────

test "comparison operators" {
    assert(3 < 5)
    assert(5 > 3)
    assert(4 <= 4)
    assert(4 >= 4)
    assert(!(3 > 5))
}

# ── constants  ─────────────────────────────────────────────────────────────────

test "top-level constant visible" {
    # PI is defined at the top of this file
    assert(PI > 3.0)
    assert(PI < 4.0)
}
