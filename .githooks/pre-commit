#!/bin/sh

set -eu

# Rust files
staged_rust_files="$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')"

# C/C++ files
staged_cpp_files="$(git diff --cached --name-only --diff-filter=ACMR -- \
  '*.c' '*.cc' '*.cpp' '*.cxx' \
  '*.h' '*.hh' '*.hpp' '*.hxx')"

# Exit early if nothing relevant staged
if [ -z "$staged_rust_files" ] && [ -z "$staged_cpp_files" ]; then
  exit 0
fi

# ---- Rust formatting ----
if [ -n "$staged_rust_files" ]; then
  echo "pre-commit: running cargo fmt --all"
  cargo fmt --all

  echo "$staged_rust_files" | while IFS= read -r file; do
    if [ -n "$file" ] && [ -f "$file" ]; then
      git add "$file"
    fi
  done

  echo "pre-commit: Rust files formatted and re-staged"
fi

# ---- C/C++ formatting ----
if [ -n "$staged_cpp_files" ]; then
  echo "pre-commit: running clang-format"

  echo "$staged_cpp_files" | while IFS= read -r file; do
    if [ -n "$file" ] && [ -f "$file" ]; then
      clang-format -i "$file"
      git add "$file"
    fi
  done

  echo "pre-commit: C/C++ files formatted and re-staged"
fi

# ---- Clippy ----
if [ -n "$staged_rust_files" ]; then
  echo "pre-commit: running cargo clippy --workspace --all-targets -- -D warnings"
  cargo clippy --workspace --all-targets -- -D warnings
fi

echo "pre-commit: formatting and checks passed"
