#/
  release_mega_1_0.fdn
  ---------------------------------------------------------------------------
  Purpose:
    Massive pre-release smoke suite for Fidan 1.0.0.

  How to use:
    fidan run  test/examples/release_mega_1_0.fdn
    fidan test test/examples/release_mega_1_0.fdn

  Optional FFI preparation:
    pwsh ./LOCAL/extern-cpp/build.ps1
    cargo build -p fidan-extern-fixture

  Notes:
    - The top-level smoke section exercises broad runtime behavior.
    - The test blocks exercise deeper syntax, stdlib, and edge cases.
    - FFI checks run only when the local DLLs are present.
    - This file intentionally contains a long coverage appendix so it can also
      act as a human-auditable 1.0.0 release checklist.
/#

use std.io
use std.math
use std.time
use std.regex
use std.string as strings
use std.collections
use std.parallel.{parallelMap, parallelFilter, parallelReduce, parallelForEach, parallel_map, parallel_filter, parallel_reduce}

use std.io.{readFile, writeFile, appendFile}
use std.math.{abs, sqrt, floor, ceil, round, max, min}
use std.string.{toUpper, toLower}

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "add_i64")
action cppAdd with (a oftype integer, b oftype integer) returns integer

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "scale_f64")
action cppScale with (value oftype float, factor oftype float) returns float

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "sum3_i64")
action cppSum3 with (
    a oftype integer,
    b oftype integer,
    c oftype integer
) returns integer

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "mix4_native")
action cppMix4 with (
    a oftype integer,
    b oftype float,
    c oftype boolean,
    d oftype handle
) returns integer

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "negate_bool")
action cppNegate with (value oftype boolean) returns boolean

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "make_handle")
action cppMakeHandle returns handle

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "inc_handle")
action cppIncHandle with (h oftype handle) returns handle

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "read_handle")
action cppReadHandle with (h oftype handle) returns integer

@extern("./LOCAL/extern-cpp/ffi_demo.dll", symbol = "free_handle")
action cppFreeHandle with (h oftype handle)

@extern("./target/debug/fidan_extern_fixture.dll", symbol = "fidan_fixture_native_add")
action fixtureNativeAdd with (a oftype integer, b oftype integer) returns integer

@unsafe
@extern("./target/debug/fidan_extern_fixture.dll", symbol = "fidan_fixture_add_boxed", abi = "fidan")
action fixtureBoxedAdd with (a oftype integer, b oftype integer) returns integer

@unsafe
@extern("./target/debug/fidan_extern_fixture.dll", symbol = "fidan_fixture_echo_boxed", abi = "fidan")
action fixtureBoxedEcho with (text oftype string) returns string

const var RELEASE_NAME = "Fidan 1.0.0 Mega Smoke"
const var RELEASE_MAJOR = 1
const var RELEASE_MINOR = 0
const var RELEASE_PATCH = 0

var GLOBAL_COUNTER = 0
var GLOBAL_GREETING = "hello release"
var GLOBAL_SCORES = {"alpha": 10, "beta": 20}

var MEGA_ROOT = io.join("LOCAL", "release-mega-" + string(time.now()))
var MEGA_TEXT = io.join(MEGA_ROOT, "alpha.txt")
var MEGA_COPY = io.join(MEGA_ROOT, "alpha-copy.txt")
var MEGA_RENAMED = io.join(MEGA_ROOT, "alpha-renamed.txt")

action approx_equal with (
    certain a oftype float,
    certain b oftype float,
    optional rel_tol oftype float = 0.0000001,
    optional abs_tol oftype float = 0.0001
) returns boolean {
    var diff = math.abs(a - b)
    var scale = math.max(math.abs(a), math.abs(b))
    return diff <= abs_tol or diff <= scale * rel_tol
}

action contains_value with (items, needle) returns boolean {
    var idx = 0
    while idx < len(items) {
        if items[idx] == needle {
            return true
        }
        idx += 1
    }
    return false
}

action factorial with (certain n oftype integer) returns integer {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

action fib with (certain n oftype integer) returns integer {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

action double_int with (certain n oftype integer) returns integer {
    return n * 2
}

action triple_int with (certain n oftype integer) returns integer {
    return n * 3
}

action is_even with (certain n oftype integer) returns boolean {
    return n % 2 == 0
}

action add_pair with (certain a oftype integer, certain b oftype integer) returns integer {
    return a + b
}

action reduce_sum with (certain acc oftype integer, certain item oftype integer) returns integer {
    return acc + item
}

action apply_to_integer with (certain value oftype integer, fn) returns integer {
    return fn(value)
}

action greater_than_five with (certain value oftype integer) returns boolean {
    return value > 5
}

parallel action slow_double with (certain value oftype integer) returns integer {
    time.sleep(5)
    return value * 2
}

object Animal {
    var species oftype string = "Unknown"
    var sound oftype string = "..."

    new with (certain species oftype string, certain sound oftype string) {
        this.species = species
        this.sound = sound
    }

    action describe returns string {
        return "I am a {this.species} and I say {this.sound}"
    }
}

object Dog extends Animal {
    var name oftype string = "unnamed"

    new with (certain name oftype string) {
        this.name = name
        parent("Dog", "Woof")
    }

    action greet returns string {
        return "Hi, I am {this.name}! {this.describe()}"
    }

    action fetch with (certain item oftype string) returns string {
        return "{this.name} fetched the {item}!"
    }
}

object GuideDog extends Dog {
    var owner oftype string = "nobody"

    new with (certain name oftype string, certain owner oftype string) {
        parent(name)
        this.owner = owner
    }

    action guide returns string {
        return "{this.name} is guiding {this.owner}"
    }
}

object Point {
    var x oftype float = 0.0
    var y oftype float = 0.0

    new with (certain x oftype float, certain y oftype float) {
        this.x = x
        this.y = y
    }

    action distance_to with (certain other oftype Point) returns float {
        var dx = this.x - other.x
        var dy = this.y - other.y
        return sqrt(dx * dx + dy * dy)
    }

    action as_text returns string {
        return "({this.x}, {this.y})"
    }
}

object Ledger {
    var name oftype string = "default"
    var entries = []

    new with (certain name oftype string) {
        this.name = name
        this.entries = []
    }

    action add with (certain amount oftype integer) returns nothing {
        this.entries.append(amount)
    }

    action total returns integer {
        var sum = 0
        for item in this.entries {
            sum += item
        }
        return sum
    }

    action describe returns string {
        return this.name + ":" + string(this.total())
    }
}

# ── Top-Level Smoke Run ──────────────────────────────────────────────────────

print("=== {RELEASE_NAME} ===")
print("version: {RELEASE_MAJOR}.{RELEASE_MINOR}.{RELEASE_PATCH}")
print("cwd: " + io.cwd())
print("type(RELEASE_NAME): " + type(RELEASE_NAME))

var base_integer = 10
var base_float = 2.5
var base_boolean = true
var base_string = "release"
var base_nothing = nothing

assert_eq(base_integer + 32, 42)
assert_eq(base_float * 4.0, 10.0)
assert_eq(boolean(1), true)
assert_eq(string(99), "99")
assert_eq(integer("42"), 42)
assert_eq(float("3.5"), 3.5)
assert(base_nothing == nothing)

var tuple3 = (10, 20, 30)
var (left_part, middle_part, right_part) = tuple3
assert_eq(left_part, 10)
assert_eq(middle_part, 20)
assert_eq(right_part, 30)

var math_value = abs(-7)
assert_eq(math_value, 7)
assert_eq(floor(3.7), 3)
assert_eq(ceil(3.2), 4)
assert_eq(round(2.5), 3)
assert_eq(max(9, 2), 9)
assert_eq(min(9, 2), 2)
assert(approx_equal(sqrt(16.0), 4.0))

var interpolation_name = "Fidan"
assert_eq("Hello, {interpolation_name}", "Hello, Fidan")
assert_eq("2 + 3 = {2 + 3}", "2 + 3 = 5")

var list_values = [1, 2, 3, 4, 5]
var doubled_values = [x * 2 for x in list_values]
var filtered_values = [x for x in list_values if x % 2 == 0]
var squared_map = {x: x * x for x in list_values}
assert_eq(len(doubled_values), 5)
assert_eq(doubled_values[0], 2)
assert_eq(filtered_values[1], 4)
assert_eq(squared_map[4], 16)

var slicing_values = [1, 2, 3, 4, 5, 6, 7, 8]
assert_eq(len(slicing_values[2..5]), 3)
assert_eq(slicing_values[2..5][0], 3)
assert_eq(slicing_values[..3][2], 3)
assert_eq(slicing_values[5..][0], 6)
assert_eq(slicing_values[0..8 step 2][2], 5)
assert_eq("hello"[1..4], "ell")

var checked_grade = check "B" {
    "A" => "excellent"
    "B" => "good"
    "C" => "average"
    _ => "fallback"
}
assert_eq(checked_grade, "good")

var fallback_status = "unset"
check "Z" {
    "A" => { fallback_status = "A" }
    _ => { fallback_status = "other" }
}
assert_eq(fallback_status, "other")

var ternary_status = "pass" if 75 >= 60 else "fail"
var maybe_name = nothing
assert_eq(ternary_status, "pass")
assert_eq(maybe_name ?? "guest", "guest")
assert_eq("present" ?? "fallback", "present")

var loop_sum = 0
for n in 1...5 {
    loop_sum += n
}
assert_eq(loop_sum, 15)

var while_value = 0
while while_value < 3 {
    while_value += 1
}
assert_eq(while_value, 3)

var nested_counter = 0
for outer in 1..4 {
    for inner in 1..(outer + 1) {
        nested_counter += 1
    }
}
assert_eq(nested_counter, 6)

var fido = Dog("Fido")
var buddy = GuideDog("Buddy", "Alice")
var p1 = Point(0.0, 0.0)
var p2 = Point(3.0, 4.0)
var ledger = Ledger("release")
ledger.add(10)
ledger.add(20)
ledger.add(12)
assert_eq(ledger.total(), 42)
assert_eq(string(fido), "<Dog>")
assert_eq(fido.fetch("stick"), "Fido fetched the stick!")
assert_eq(buddy.guide(), "Buddy is guiding Alice")
assert(approx_equal(p1.distance_to(p2), 5.0))

var greet_lambda = action { return "hello from lambda" }
var square_lambda = action with (certain x oftype integer) { return x * x }
var values_for_each = []
var for_each_source = [1, 2, 3]
assert_eq(greet_lambda(), "hello from lambda")
assert_eq(square_lambda(8), 64)
for_each_source.forEach(action with (n) { values_for_each.append(n * 10) })
assert_eq(len(values_for_each), 3)
assert_eq(values_for_each[2], 30)

var first_even = [1, 3, 4, 8].firstWhere(action with (n) { return n % 2 == 0 })
assert_eq(first_even, 4)

var spawned = spawn slow_double(21)
var spawned_result = await spawned
assert_eq(spawned_result, 42)

var shared_a = Shared(0)
var shared_b = Shared(0)
parallel {
    task A { shared_a.set(20) }
    task B { shared_b.set(22) }
}
assert_eq(shared_a.get() + shared_b.get(), 42)

var parallel_seen = Shared(0)
parallel for item in [1, 2, 3, 4] {
    parallel_seen.set(parallel_seen.get() + item)
}
assert(parallel_seen.get() >= 1)

var concurrent_capture = "release"
concurrent {
    task { print("concurrent A -> " + concurrent_capture) }
    task { print("concurrent B -> " + concurrent_capture) }
}

var mapped_parallel = parallelMap([1, 2, 3, 4], double_int)
var filtered_parallel = parallelFilter([1, 2, 3, 4, 5, 6], is_even)
var reduced_parallel = parallelReduce([1, 2, 3, 4], 0, reduce_sum)
assert_eq(len(mapped_parallel), 4)
assert_eq(mapped_parallel[3], 8)
assert_eq(len(filtered_parallel), 3)
assert_eq(filtered_parallel[0], 2)
assert_eq(reduced_parallel, 10)

var regex_match = regex.find("\\d+", "release 42 candidate")
var regex_all = regex.findAll("\\d+", "a1 b22 c333")
var regex_caps = regex.capture("(\\w+)@(\\w+\\.\\w+)", "user@example.com")
assert_eq(regex_match, "42")
assert_eq(len(regex_all), 3)
assert_eq(regex_caps[1], "user")
assert_eq(regex.replace("o", "hello world", "0"), "hell0 world")
assert_eq(regex.replaceAll("o", "hello world", "0"), "hell0 w0rld")

var now_ms = time.now()
time.sleep(1)
var elapsed_ms = time.elapsed(now_ms)
assert(elapsed_ms >= 0)
assert_eq(len(time.date(now_ms)), 10)
assert_eq(len(time.time(now_ms)), 8)
assert(time.year(now_ms) >= 1970)
assert(time.month(now_ms) >= 1)
assert(time.day(now_ms) >= 1)

assert(io.makeDir(MEGA_ROOT))
assert(writeFile(MEGA_TEXT, "alpha"))
assert(appendFile(MEGA_TEXT, "\nbeta"))
assert(io.fileExists(MEGA_TEXT))
assert(io.isFile(MEGA_TEXT))
assert(io.isDir(MEGA_ROOT))
assert_eq(readFile(MEGA_TEXT).contains("beta"), true)
assert(io.copyFile(MEGA_TEXT, MEGA_COPY))
assert(io.renameFile(MEGA_COPY, MEGA_RENAMED))
assert(io.fileExists(MEGA_RENAMED))
assert_eq(io.basename(MEGA_RENAMED), "alpha-renamed.txt")
assert_eq(io.extension(MEGA_RENAMED), "txt")
assert(contains_value(io.listDir(MEGA_ROOT), "alpha.txt"))
assert(contains_value(io.listDir(MEGA_ROOT), "alpha-renamed.txt"))
assert(io.absolutePath(MEGA_RENAMED).contains("alpha-renamed.txt"))
io.setEnv("FIDAN_RELEASE_MEGA", "active")
assert_eq(io.getEnv("FIDAN_RELEASE_MEGA"), "active")
assert(len(io.args()) >= 1)

var text_sentence = "  Fidan Release Candidate  "
assert_eq(text_sentence.trim(), "Fidan Release Candidate")
assert_eq(toUpper("fidan"), "FIDAN")
assert_eq(toLower("FIDAN"), "fidan")
assert_eq(strings.capitalize("release"), "Release")
assert_eq(strings.contains("release-candidate", "candidate"), true)
assert_eq(strings.startsWith("release-candidate", "release"), true)
assert_eq(strings.endsWith("release-candidate", "candidate"), true)
assert_eq(strings.indexOf("release-candidate", "candidate"), 8)
assert_eq(strings.lastIndexOf("bananas", "a"), 5)
assert_eq(strings.replace("banana", "na", "NA"), "baNANA")
assert_eq(strings.replaceFirst("banana", "na", "NA"), "baNAna")
assert_eq(strings.slice("release", 1, 4), "ele")
assert_eq(strings.substr("release", 2, 5), "lea")
assert_eq(strings.padStart("7", 3, "0"), "007")
assert_eq(strings.padEnd("7", 3, "0"), "700")
assert_eq(strings.repeat("ha", 3), "hahaha")
assert_eq(strings.reverse("abc"), "cba")
assert_eq(strings.len("hello"), 5)
assert_eq(strings.isEmpty(""), true)
var fmt_pair = "A:" + strings.fromCharCode(123) + strings.fromCharCode(125) + " B:" + strings.fromCharCode(123) + strings.fromCharCode(125)
assert_eq(strings.format(fmt_pair, "x", 7), "A:x B:7")
assert_eq(strings.parseInt("42"), 42)
assert_eq(strings.parseFloat("3.25"), 3.25)
assert_eq(strings.fromChars(["o", "k"]), "ok")
assert_eq(strings.charCode("A"), 65)
assert_eq(strings.fromCharCode(66), "B")

var ranged = collections.range(1, 6)
assert_eq(len(ranged), 5)
assert_eq(ranged[0], 1)
assert_eq(ranged[4], 5)

var set_a = collections.hashset(["a", "b"])
var set_b = collections.hashset(["b", "c"])
collections.setAdd(set_a, "d")
collections.setRemove(set_a, "a")
assert_eq(collections.setContains(set_a, "b"), true)
assert_eq(collections.setContains(set_a, "a"), false)
assert(collections.setLen(set_a) >= 2)
assert(collections.setLen(collections.setUnion(set_a, set_b)) >= 3)
assert(collections.setLen(collections.setIntersect(set_a, set_b)) >= 1)
assert(collections.setLen(collections.setDiff(set_b, set_a)) >= 0)

var queue = collections.Queue([1, 2])
collections.enqueue(queue, 3)
assert_eq(collections.peek(queue), 1)
assert_eq(collections.dequeue(queue), 1)
assert_eq(collections.peek(queue), 2)

var stack = collections.Stack([1, 2])
collections.push(stack, 3)
assert_eq(collections.top(stack), 3)
assert_eq(collections.pop(stack), 3)
assert_eq(collections.stackPeek(stack), 2)

assert_eq(len(collections.flatten([[1, 2], [3, 4]])), 4)
assert_eq(len(collections.zip([1, 2, 3], ["a", "b"])), 2)
assert_eq(len(collections.unique([1, 1, 2, 2, 3])), 3)
assert_eq(collections.reverse([1, 2, 3])[0], 3)
assert_eq(collections.sort([3, 1, 2])[0], 1)
assert_eq(collections.count([1, 2, 3]), 3)
assert_eq(collections.isEmpty([]), true)
assert_eq(len(collections.concat([1, 2], [3, 4])), 4)
assert_eq(len(collections.slice([1, 2, 3, 4, 5], 1, 4)), 3)
assert_eq(collections.first([7, 8, 9]), 7)
assert_eq(collections.last([7, 8, 9]), 9)
assert_eq(collections.join(["a", "b", "c"], "-"), "a-b-c")
assert_eq(collections.sum([1, 2, 3, 4]), 10)
assert_eq(collections.product([1, 2, 3, 4]), 24)
assert_eq(collections.min([9, 3, 7]), 3)
assert_eq(collections.max([9, 3, 7]), 9)

var ffi_cpp_exists = io.fileExists("./LOCAL/extern-cpp/ffi_demo.dll")
var ffi_fixture_exists = io.fileExists("./target/debug/fidan_extern_fixture.dll")

if ffi_cpp_exists {
    assert_eq(cppAdd(20, 22), 42)
    assert(approx_equal(cppScale(2.5, 4.0), 10.0))
    assert_eq(cppSum3(10, 20, 12), 42)
    var cpp_handle = cppMakeHandle()
    assert_eq(cppMix4(7, 8.0, true, cpp_handle), 156)
    assert_eq(cppNegate(true), false)
    cpp_handle = cppIncHandle(cpp_handle)
    assert_eq(cppReadHandle(cpp_handle), 42)
    cppFreeHandle(cpp_handle)
} otherwise {
    print("ffi note: skipped local C++ DLL smoke because `./LOCAL/extern-cpp/ffi_demo.dll` is missing")
}

if ffi_fixture_exists {
    # Release-blocker smoke: boxed `abi = "fidan"` fixture calls currently crash
    # on Windows interpreter mode if the runtime/FFI layer regresses.
    assert_eq(fixtureNativeAdd(20, 22), 42)
    assert_eq(fixtureBoxedAdd(10, 32), 42)
    assert_eq(fixtureBoxedEcho("hello"), "hello")
} otherwise {
    print("ffi note: skipped fixture DLL smoke because `./target/debug/fidan_extern_fixture.dll` is missing")
}

attempt {
    panic("release smoke panic")
} catch err {
    assert_eq(err, "release smoke panic")
} finally {
    GLOBAL_COUNTER += 1
}
assert_eq(GLOBAL_COUNTER, 1)

print("top-level smoke finished")

# ── Test Blocks: Core Syntax ────────────────────────────────────────────────

test "release metadata constants" {
    assert_eq(RELEASE_NAME, "Fidan 1.0.0 Mega Smoke")
    assert_eq(RELEASE_MAJOR, 1)
    assert_eq(RELEASE_MINOR, 0)
    assert_eq(RELEASE_PATCH, 0)
}

test "basic primitive types" {
    var i = 42
    var f = 3.5
    var b = true
    var s = "hello"
    var n = nothing
    assert_eq(type(i), "integer")
    assert_eq(type(f), "float")
    assert_eq(type(b), "boolean")
    assert_eq(type(s), "string")
    assert_eq(type(n), "nothing")
}

test "const and mutable globals" {
    var local_counter = GLOBAL_COUNTER
    assert(local_counter >= 1)
    GLOBAL_SCORES["gamma"] = 30
    assert_eq(GLOBAL_SCORES["gamma"], 30)
}

test "arithmetic operators" {
    assert_eq(2 + 3, 5)
    assert_eq(7 - 2, 5)
    assert_eq(6 * 7, 42)
    assert_eq(84 / 2, 42)
    assert_eq(85 % 43, 42 % 43)
    assert_eq(2 ** 5, 32)
}

test "comparison operators" {
    assert(5 > 4)
    assert(4 < 5)
    assert(5 >= 5)
    assert(5 <= 5)
    assert(5 == 5)
    assert(5 != 4)
}

test "logical operators" {
    assert(true and true)
    assert(true or false)
    assert(!(false or false))
    assert(not false)
}

test "compound assignment style flow" {
    var value = 5
    value += 3
    value -= 1
    value *= 2
    value /= 2
    assert_eq(value, 7)
}

test "string interpolation" {
    var user = "alice"
    var age = 30
    assert_eq("user={user}", "user=alice")
    assert_eq("age={age}", "age=30")
    assert_eq("calc={1 + 2 * 3}", "calc=7")
}

test "tuple destructuring" {
    var t = (1, 2, 3)
    var (a, b, c) = t
    assert_eq(a, 1)
    assert_eq(b, 2)
    assert_eq(c, 3)
}

test "dictionary basics" {
    var scores = {"alice": 10, "bob": 20}
    scores["cara"] = 30
    assert_eq(scores["alice"], 10)
    assert_eq(scores["cara"], 30)
    assert_eq(len(scores), 3)
}

test "list append remove contains find" {
    var xs = [3, 1, 4]
    xs.append(5)
    assert_eq(len(xs), 4)
    assert_eq(xs.contains(4), true)
    assert(xs.find(5) >= 0)
    assert_eq(xs.remove(0), 3)
}

test "while and break continue" {
    var total = 0
    for n in 1..10 {
        if n % 2 == 0 {
            continue
        }
        if n > 7 {
            break
        }
        total += n
    }
    assert_eq(total, 1 + 3 + 5 + 7)
}

test "inclusive ranges" {
    var total = 0
    for n in 1...5 {
        total += n
    }
    assert_eq(total, 15)
}

test "check expression and wildcard" {
    var label = check 2 {
        1 => "one"
        2 => "two"
        _ => "other"
    }
    assert_eq(label, "two")
}

test "attempt catch finally" {
    var caught = "no"
    var finalized = false
    attempt {
        panic("boom")
    } catch err {
        caught = err
    } finally {
        finalized = true
    }
    assert_eq(caught, "boom")
    assert_eq(finalized, true)
}

test "objects inheritance and parent constructor" {
    var rex = Dog("Rex")
    var buddy2 = GuideDog("Buddy", "Lina")
    assert_eq(rex.fetch("ball"), "Rex fetched the ball!")
    assert_eq(buddy2.guide(), "Buddy is guiding Lina")
    assert(string(rex).contains("Dog"))
}

test "point distance object method" {
    var a = Point(0.0, 0.0)
    var b = Point(6.0, 8.0)
    assert(approx_equal(a.distance_to(b), 10.0))
    assert_eq(a.as_text(), "(0.0, 0.0)")
}

test "ledger object aggregation" {
    var local_ledger = Ledger("test")
    local_ledger.add(10)
    local_ledger.add(15)
    local_ledger.add(17)
    assert_eq(local_ledger.total(), 42)
}

test "recursion factorial" {
    assert_eq(factorial(1), 1)
    assert_eq(factorial(5), 120)
    assert_eq(factorial(6), 720)
}

test "recursion fibonacci" {
    assert_eq(fib(0), 0)
    assert_eq(fib(1), 1)
    assert_eq(fib(7), 13)
}

